def tag(t="SPDL"): return f"{Col.bold}{Col.blue}[{t}]{Col.reset}"
def die(msg): print(f"{Col.red}{Col.bold}[ERROR]{Col.reset} {msg}", file=sys.stderr); sys.exit(1)
def warn(msg): print(f"{Col.yellow}{Col.bold}[WARN]{Col.reset} {msg}", file=sys.stderr)
def site(provider, s):
    c={"spigot":Col.yellow,"modrinth":Col.green,"hangar":Col.cyan}.get(provider, "")
