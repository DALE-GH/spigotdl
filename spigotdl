def http_json(url):
    req=urllib.request.Request(url, headers={"User-Agent":CFG["SPDL_USER_AGENT"],"Accept":"application/json"})
    with urllib.request.urlopen(req, timeout=35) as r: return json.loads(r.read().decode(r.headers.get_content_charset() or "utf-8", "replace"))

def http_download(url, path):
    req=urllib.request.Request(url, headers={"User-Agent":CFG["SPDL_USER_AGENT"]})
    with urllib.request.urlopen(req, timeout=120) as r, open(path,"wb") as f: shutil.copyfileobj(r,f)

def enc(s): return urllib.parse.quote(str(s), safe="")
def safe_name(s):
    s=re.sub(r"[^A-Za-z0-9._+-]+","-",str(s or "plugin")).strip("-")
    return s if s.lower().endswith(".jar") else s+".jar"
def validate_jar(p):
    try:
        with zipfile.ZipFile(p) as z: return z.testzip() is None
    except Exception: return False

def roots(): return [Path(x) for x in CFG["SPDL_SERVER_ROOTS"].split(":") if x]

def server_dir_from_conf(name):
    p=Path(CFG["SPDL_CONF_DIR"])/f"{name}.conf"
    if not p.exists(): return None
    key=CFG["SPDL_SERVER_DIR_VAR"]
    for raw in p.read_text(errors="replace").splitlines():
        line=raw.strip()
        if line.startswith("export "): line=line[7:].strip()
        if not line or line.startswith("#") or "=" not in line: continue
        k,v=line.split("=",1)
        if k.strip()==key: return Path(v.strip().strip("'\""))
    return None

def resolve_server(name="", server_dir="", plugin_dir=""):
    if plugin_dir:
        pd=Path(plugin_dir); return {"name":name or pd.parent.name,"server_dir":pd.parent,"plugin_dir":pd}
    if server_dir:
        sd=Path(server_dir); return {"name":name or sd.name,"server_dir":sd,"plugin_dir":sd/CFG["SPDL_PLUGINS_DIR_NAME"]}
    conf=server_dir_from_conf(name)
    if conf: return {"name":name,"server_dir":conf,"plugin_dir":conf/CFG["SPDL_PLUGINS_DIR_NAME"]}
    for root in roots():
        if (root/name).is_dir(): return {"name":name,"server_dir":root/name,"plugin_dir":root/name/CFG["SPDL_PLUGINS_DIR_NAME"]}
    root=roots()[0] if roots() else Path("/opt/mc")
    return {"name":name,"server_dir":root/name,"plugin_dir":root/name/CFG["SPDL_PLUGINS_DIR_NAME"]}

def list_servers():
    names=set(); ex=re.compile(CFG["SPDL_EXCLUDE_REGEX"])
    cd=Path(CFG["SPDL_CONF_DIR"])
    if cd.is_dir():
        for p in cd.glob("*.conf"):
            if not ex.search(p.stem): names.add(p.stem)
    for root in roots():
        if root.is_dir():
            for p in root.iterdir():
                if p.is_dir() and not ex.search(p.name): names.add(p.name)
    return [resolve_server(n) for n in sorted(names)]

def choose_server():
    ss=list_servers()
    if not ss:
        n=input("Server name: ").strip(); return resolve_server(n)
    print(f"{tag()} Servers")
    for i,s in enumerate(ss,1): print(f"  {i}) {s['name']:<18} {Col.dim}{s['server_dir']}{Col.reset}")
    c=input("Select server [number/name]: ").strip()
    if c.isdigit() and 1 <= int(c) <= len(ss): return ss[int(c)-1]
    return resolve_server(c)

def ensure_server(s):
    if not s["server_dir"].exists(): die(f"Server directory does not exist: {s['server_dir']}")
    s["plugin_dir"].mkdir(parents=True, exist_ok=True)

def reg_path(s): return s["plugin_dir"]/CFG["SPDL_REGISTRY_DIR"]/CFG["SPDL_REGISTRY_FILE"]
def read_reg(s):
    p=reg_path(s)
    if not p.exists(): return []
    with p.open(newline="", errors="replace") as f: return list(csv.DictReader(f, delimiter="\t"))
def write_reg(s, rows):
    p=reg_path(s); p.parent.mkdir(parents=True, exist_ok=True)
    with p.open("w", newline="") as f:
        w=csv.DictWriter(f, REG_COLS, delimiter="\t", extrasaction="ignore"); w.writeheader(); [w.writerow({c:r.get(c,"") for c in REG_COLS}) for r in rows]
def migrate_reg(s):
    p=reg_path(s)
    if not p.exists(): return
    first=p.read_text(errors="replace").splitlines()[:1]
    if not first or first[0].split("\t")==REG_COLS: return
    if "resource_id" not in first[0]: return
    with p.open(newline="", errors="replace") as f: old=list(csv.DictReader(f, delimiter="\t"))
    new=[]
    for r in old:
        new.append({"provider":"spigot","project_id":r.get("resource_id",""),"version_id":r.get("version_id",""),"filename":r.get("filename",""),"project_name":r.get("resource_name",""),"release_type":"release","loaders":"bukkit,spigot,paper","game_versions":"","installed_at":r.get("installed_at",now()),"source":"migrated"})
    shutil.copy2(p, p.with_suffix(p.suffix+f".v1.bak.{int(time.time())}")); write_reg(s,new); warn(f"Migrated registry to v2: {p}")
def upsert_reg(s,row):
    rows=[r for r in read_reg(s) if not (r.get("provider")==row.get("provider") and r.get("project_id")==row.get("project_id"))]
    rows.append(row); write_reg(s, rows)

class Version:
    def __init__(self, provider, project_id, version_id, name, release_type, loaders, versions, filename, url):
        self.provider=provider; self.project_id=str(project_id); self.version_id=str(version_id or ""); self.name=name or str(project_id); self.release_type=release_type or ""; self.loaders=loaders or ""; self.versions=versions or ""; self.filename=safe_name(filename or self.name); self.url=url
class Result:
    def __init__(self, provider, project_id, name, desc="", downloads=0, stars=0, api="", versions="", rel=""):
        self.provider=provider; self.project_id=str(project_id); self.name=name or str(project_id); self.desc=desc or ""; self.downloads=int(downloads or 0); self.stars=int(stars or 0); self.api=api or ""; self.versions=versions or ""; self.rel=rel or ""
    def ref(self): return f"{self.provider}:{self.project_id}"

class Spigot:
    name="spigot"
    def base(self): return CFG["SPDL_SPIGET_API"].rstrip("/")
    def search(self,q,limit,sort,api="",mc="",rel=""):
        sp_sort="-downloads" if sort in ("downloads","stars") else "-updateDate"
        data=http_json(f"{self.base()}/search/resources/{enc(q)}?size={limit}&sort={enc(sp_sort)}")
        out=[]
        for x in data if isinstance(data,list) else []:
            out.append(Result("spigot", x.get("id"), x.get("name"), re.sub("<.*?>","",str(x.get("tag") or x.get("description") or ""))[:160], x.get("downloads",0), x.get("likes",0), "bukkit,spigot,paper", "", "release"))
        return out
    def latest(self,pid,api="",mc="",rel=""):
        m=http_json(f"{self.base()}/resources/{enc(pid)}"); name=m.get("name",f"spigot-{pid}"); f=m.get("file") or {}; v=m.get("version") or {}
        return Version("spigot",pid,v.get("id") or m.get("updateDate"),name,"release","bukkit,spigot,paper",mc,f.get("name") or name,f"{self.base()}/resources/{enc(pid)}/download")
class Modrinth:
    name="modrinth"
    def base(self): return CFG["SPDL_MODRINTH_API"].rstrip("/")
    def loader(self,api): return {"paper":"paper","spigot":"spigot","bukkit":"bukkit","purpur":"purpur","velocity":"velocity","waterfall":"waterfall"}.get(api.lower(), api.lower())
    def search(self,q,limit,sort,api="",mc="",rel=""):
        idx={"downloads":"downloads","stars":"follows","updated":"updated","newest":"newest"}.get(sort,"relevance")
        facets=[["project_type:mod"]]
        if api: facets.append([f"categories:{self.loader(api)}"])
        if mc: facets.append([f"versions:{mc}"])
        params=urllib.parse.urlencode({"query":q,"limit":limit,"index":idx,"facets":json.dumps(facets,separators=(",",":"))})
        data=http_json(f"{self.base()}/search?{params}"); out=[]
        for x in data.get("hits",[]) if isinstance(data,dict) else []:
            out.append(Result("modrinth", x.get("project_id") or x.get("slug"), x.get("title"), x.get("description","")[:160], x.get("downloads",0), x.get("follows",0), ",".join((x.get("categories") or [])[:8]), ",".join((x.get("versions") or [])[-5:]), rel))
        return out
    def versions(self,pid,api="",mc="",rel=""):
        params={}
        if api: params["loaders"]=json.dumps([self.loader(api)],separators=(",",":"))
        if mc: params["game_versions"]=json.dumps([mc],separators=(",",":"))
        url=f"{self.base()}/project/{enc(pid)}/version" + ("?"+urllib.parse.urlencode(params) if params else "")
        vs=http_json(url); vs = vs if isinstance(vs,list) else []
        if rel: vs=[v for v in vs if str(v.get("version_type","")).lower()==rel.lower()]
        return vs
    def latest(self,pid,api="",mc="",rel=""):
        vs=self.versions(pid,api,mc,rel)
        if not vs: raise RuntimeError(f"No Modrinth versions found for {pid}")
        v=vs[0]; files=v.get("files") or []; f=next((x for x in files if x.get("primary")), files[0] if files else None)
        if not f or not f.get("url"): raise RuntimeError(f"No downloadable file for {pid}")
        return Version("modrinth",pid,v.get("id") or v.get("version_number"), v.get("name") or pid, v.get("version_type") or rel, ",".join(v.get("loaders") or []), ",".join(v.get("game_versions") or []), f.get("filename") or pid, f.get("url"))
class Hangar:
    name="hangar"
    def base(self): return CFG["SPDL_HANGAR_API"].rstrip("/")
    def platform(self,api): return "VELOCITY" if api.lower()=="velocity" else "WATERFALL" if api.lower()=="waterfall" else "PAPER"
    def search(self,q,limit,sort,api="",mc="",rel=""):
        plat=self.platform(api) if api else ""
        urls=[]
        for key in ("query","q"):
            params={key:q,"pagination[limit]":str(limit),"pagination[offset]":"0"}
            if plat: params["platform"]=plat
            urls.append(f"{self.base()}/projects?{urllib.parse.urlencode(params)}")
        data=None; err=None
        for u in urls:
            try: data=http_json(u); break
            except Exception as e: err=e
        if data is None: raise RuntimeError(err)
        items=[]
        if isinstance(data,list): items=data
        elif isinstance(data,dict):
            for k in ("result","results","projects","data"):
                if isinstance(data.get(k),list): items=data[k]; break
        out=[]
        for x in items[:limit]:
            if not isinstance(x,dict): continue
            ns=x.get("namespace") or x.get("owner") or x.get("author") or ""; slug=x.get("slug") or x.get("name") or x.get("id") or ""
            pid=x.get("pluginId") or x.get("projectId") or x.get("id") or (f"{ns}/{slug}" if ns else slug)
            if isinstance(pid,dict): pid=pid.get("slug") or pid.get("name") or slug
            stats=x.get("stats") or {}; out.append(Result("hangar",pid,x.get("name") or slug,str(x.get("description") or x.get("summary") or "")[:160],x.get("downloads") or stats.get("downloads") or 0,x.get("stars") or stats.get("stars") or 0,plat.lower() if plat else "paper,velocity,waterfall",mc,rel))
        return out
    def latest(self,pid,api="",mc="",rel=""):
        channel={"release":"Release","beta":"Beta","snapshot":"Snapshot","alpha":"Alpha"}.get(rel.lower(),"Release") if rel else "Release"
        eid="/".join(enc(x) for x in str(pid).split("/")); meta={}
        for u in (f"{self.base()}/projects/{eid}/latest?channel={enc(channel)}", f"{self.base()}/projects/{eid}/versions/recommended"):
            try: meta=http_json(u); break
            except Exception: pass
        name=str(pid).split("/")[-1]; ver=""; fname=name+".jar"
        if isinstance(meta,dict):
            ver=str(meta.get("name") or meta.get("version") or meta.get("id") or ""); name=str(meta.get("projectName") or meta.get("name") or name)
            files=meta.get("files") or meta.get("downloads") or []
            if isinstance(files,list):
                for f in files:
                    if isinstance(f,dict) and (f.get("filename") or f.get("fileName") or f.get("name")): fname=f.get("filename") or f.get("fileName") or f.get("name"); break
        return Version("hangar",pid,ver,name,rel or "release",api or "paper",mc,fname,f"{self.base()}/projects/{eid}/versions/recommended/download")
PROVIDERS={"spigot":Spigot(),"modrinth":Modrinth(),"hangar":Hangar()}

def spigot_id(ref):
    ref=str(ref).strip(); clean=ref.split("?",1)[0].split("#",1)[0]
    if clean.isdigit(): return clean
    m=re.search(r"resources/[^/]*\.([0-9]+)", clean, re.I)
    if m: return m.group(1)
    nums=re.findall(r"[0-9]+", clean)
    return nums[-1] if nums else ref

def parse_ref(ref, default="spigot"):
    ref=str(ref).strip(); default=str(default or "spigot").strip().lower()
    if default not in PROVIDERS:
        die(f"Invalid SPDL_DEFAULT_SOURCE={default!r}. Valid options: {', '.join(PROVIDERS)}")
    if re.search(r"spigotmc\.org/resources/", ref, re.I):
        return "spigot", spigot_id(ref)
    if re.search(r"modrinth\.com/(plugin|mod)/", ref, re.I):
        clean=ref.split("?",1)[0].split("#",1)[0].rstrip("/")
        return "modrinth", clean.rsplit("/",1)[-1]
    if re.search(r"hangar\.papermc\.io/", ref, re.I):
        clean=ref.split("?",1)[0].split("#",1)[0].rstrip("/")
        parts=clean.split("/")
        if len(parts) >= 2: return "hangar", "/".join(parts[-2:])
    if ":" in ref:
        p,pid=ref.split(":",1); p=p.strip().lower()
        if p in PROVIDERS: return p,pid.strip()
    if default == "spigot":
        return "spigot", spigot_id(ref)
    return default, ref

def install_version(s,v,source="manual",name="",dry=False):
    ensure_server(s); filename=safe_name(name or v.filename); dest=s["plugin_dir"]/filename
    print(f"\n{tag()} Installing {site(v.provider,v.provider.upper())} {Col.bold}{v.name}{Col.reset}\n  Server : {s['name']}\n  Target : {dest}\n  Version: {v.version_id or 'unknown'}")
    if dry: print(f"{Col.yellow}Dry run:{Col.reset} would download {v.url}"); return
    tmp=Path(tempfile.mkstemp(prefix="spdl-", suffix=".jar")[1])
    try:
        print(f"{Col.blue}Downloading...{Col.reset}"); http_download(v.url,tmp)
        if truthy(CFG["SPDL_VALIDATE_JAR"]):
            print(f"{Col.blue}Validating jar...{Col.reset}")
            if not validate_jar(tmp):
                bad=tmp.with_suffix(".bad"); tmp.rename(bad); die(f"Downloaded file is not a valid jar. Saved bad file to {bad}")
        if dest.exists() and truthy(CFG["SPDL_BACKUP_EXISTING"]):
            bak=dest.with_name(dest.name+f".bak.{time.strftime('%Y%m%d-%H%M%S')}"); print(f"Backing up existing file: {bak}"); dest.rename(bak)
        shutil.copy2(tmp,dest); os.chmod(dest, int(CFG["SPDL_INSTALL_MODE"],8))
        if truthy(CFG["SPDL_AUTO_CHOWN"]):
            try: st=s["plugin_dir"].stat(); os.chown(dest, st.st_uid, st.st_gid)
            except Exception: pass
        upsert_reg(s,{"provider":v.provider,"project_id":v.project_id,"version_id":v.version_id,"filename":filename,"project_name":v.name,"release_type":v.release_type,"loaders":v.loaders,"game_versions":v.versions,"installed_at":now(),"source":source})
        print(f"\n{Col.green}{Col.bold}Done.{Col.reset}\n{Col.cyan}{Col.bold}Installed:{Col.reset}\n  {Col.green}{dest}{Col.reset}")
        repl={"{instance}":s["name"],"{filename}":filename,"{dest}":str(dest),"{server_dir}":str(s["server_dir"]),"{plugin_dir}":str(s["plugin_dir"])}
        for label,tpl in (("Restart command",CFG.get("SPDL_RESTART_CMD_TEMPLATE","")),("Optional live-load command",CFG.get("SPDL_PLUGMAN_CMD_TEMPLATE",""))):
            if tpl:
                for k,val in repl.items(): tpl=tpl.replace(k,val)
                print(f"\n{Col.yellow}{Col.bold}{label}:{Col.reset}\n  {Col.blue}{tpl}{Col.reset}")
    finally:
        try: tmp.unlink()
        except Exception: pass

def install_ref(s, ref, api="", mc="", rel="", name="", source="manual", dry=False):
    p,pid=parse_ref(ref, CFG["SPDL_DEFAULT_SOURCE"]); install_version(s, PROVIDERS[p].latest(pid,api,mc,rel), source, name, dry)

def _norm_rank_text(value):
    return re.sub(r"[^a-z0-9]+", "", str(value or "").lower())

def search_all(q, sources, limit, sort, api="", mc="", rel=""):
    out=[]
    for p in sources:
        try:
            out += PROVIDERS[p].search(q,limit,sort,api,mc,rel)
        except Exception as e:
            warn(f"{p} search failed: {e}")
    qn=_norm_rank_text(q)
    def rank(r):
        rn=_norm_rank_text(r.name)
        rd=_norm_rank_text(r.desc)
        if rn == qn: match=0
        elif rn.startswith(qn): match=1
        elif qn and qn in rn: match=2
        elif qn and qn in rd: match=3
        else: match=4
        provider_order={"spigot":0,"modrinth":1,"hangar":2}.get(r.provider,9)
        return (match, -int(getattr(r,"downloads",0) or 0), provider_order, str(r.name).lower())
    return sorted(out, key=rank)

def search_page_size():
    try:
        return max(1, int(CFG.get("SPDL_SEARCH_PAGE_SIZE", "10")))
    except Exception:
        return 10

def print_results(rs, page=1, page_size=None, title="Search Results", context_lines=None, footer=""):
    if not rs:
        print(f"{Col.yellow}No results found.{Col.reset}")
        return

    page_size = page_size or search_page_size()
    total=len(rs)
    start=(page-1)*page_size
    end=min(start+page_size,total)
    width=max(2,len(str(end)))

    print(f"\n{tag()} {title} {Col.dim}({start+1}-{end} of {total}){Col.reset}")

    if context_lines:
        for line in context_lines:
            print(line)
        print()

    for i,r in enumerate(rs[start:end],start+1):
        print(f"{Col.bold}{i:>{width}}){Col.reset} {site(r.provider,'['+r.provider.upper()+']')} {Col.bold}{r.name}{Col.reset}")
        print(f"     ID        : {r.ref()}")
        if r.desc: print(f"     Summary   : {r.desc}")
        print(f"     Downloads : {r.downloads}")
        if r.stars: print(f"     Stars     : {r.stars}")
        if r.api: print(f"     API/Loader: {r.api}")
        if r.versions: print(f"     Versions  : {r.versions}")
        if r.rel: print(f"     Release   : {r.rel}")
        print()

    if footer:
        print(f"{Col.dim}{footer}{Col.reset}")

def prompt_result_choice(prompt, result_count, allow_more=False, visible_count=None, context=""):
    visible_count = visible_count or min(search_page_size(), result_count)
    visible_count = min(max(0, visible_count), result_count)

    parts = []
    if visible_count:
        parts.append(f"1-{visible_count}")
    parts.append("s=skip/next")
    parts.append("q=quit/back")
    if allow_more:
        parts.append("m=more")
    suffix="[" + " / ".join(parts) + "]: "

    while True:
        if context:
            print(f"{Col.dim}{context}{Col.reset}")
        c=input(prompt + " " + suffix).strip().lower()

        if c in ("", "s", "skip", "n", "next"):
            return "skip"
        if c in ("q", "quit", "exit", "b", "back"):
            return "quit"
        if allow_more and c in ("m", "more", "+"):
            return "more"
        if c.isdigit() and 1 <= int(c) <= visible_count:
            return int(c) - 1

        if visible_count:
            warn(f"Invalid choice. Enter 1-{visible_count}, s/next to skip, q/back to quit" + (", or m for more." if allow_more else "."))
        else:
            warn("Invalid choice. Enter s/next to skip or q/back to quit" + (", or m for more." if allow_more else "."))

def update_server(s,dry=False):
    ensure_server(s); migrate_reg(s); rows=read_reg(s); checked=outdated=updated=failed=0
    if not rows: warn(f"No registry for {s['name']}. Run: spigotdl scan --server {s['name']}"); return (0,0,0,0)
    print(f"\n{tag()} Updating {s['name']}")
    for r in rows:
        p=PROVIDERS.get(r.get("provider"));
        if not p: failed+=1; continue
        checked+=1
        try: v=p.latest(r.get("project_id",""),(r.get("loaders","").split(",")[0] if r.get("loaders") else ""),(r.get("game_versions","").split(",")[0] if r.get("game_versions") else ""),r.get("release_type",""))
        except Exception as e: warn(f"Check failed for {r.get('project_name')}: {e}"); failed+=1; continue
        if v.version_id and v.version_id==r.get("version_id"):
            print(f"  {Col.green}OK{Col.reset} {r.get('project_name') or v.name} ({v.version_id})")
        else:
            outdated+=1; print(f"  {Col.yellow}UPDATE{Col.reset} {r.get('project_name') or v.name}: {r.get('version_id') or 'unknown'} -> {v.version_id or 'unknown'}")
            if not dry: install_version(s,v,"update"); updated+=1
    print(f"\n{tag()} Update summary: checked={checked} outdated={outdated} updated={updated} failed={failed}")
    return checked,outdated,updated,failed

def guess_name(jar):
    n=Path(jar).stem; n=re.sub(r"[-_. ]+v?\d[\w.+-]*$","",n); return re.sub(r"[-_. ]+(bukkit|spigot|paper|velocity|waterfall|fabric|forge)$","",n,flags=re.I) or Path(jar).stem

def scan_server(s,sources,yes=False,dry=False):
    ensure_server(s); migrate_reg(s)
    tracked={r.get("filename") for r in read_reg(s)}
    jars=sorted(list(s["plugin_dir"].glob("*.jar"))+list(s["plugin_dir"].glob("*.JAR")))
    total_jars=len(jars)
    page_step=search_page_size()
    added=skipped=0

    if yes:
        print(f"\n{tag()} Scanning {s['name']}\n  Plugin dir: {s['plugin_dir']}")

    for idx,jar in enumerate(jars,1):
        if jar.name in tracked:
            if yes:
                print(f"{Col.dim}tracked:{Col.reset} {jar.name}")
            continue

        q=guess_name(jar)
        limit=max(page_step, int(CFG.get("SPDL_SEARCH_LIMIT", "25")))
        rs=search_all(q,sources,limit,"relevance")

        if not rs:
            skipped+=1
            if yes:
                warn(f"No match for {jar.name}")
            else:
                clear_screen(); brand()
                print(f"{tag()} Tracking Plugin {idx}/{total_jars}")
                print(f"  Server    : {s['name']}")
                print(f"  Plugin dir: {s['plugin_dir']}")
                print(f"  Plugin    : {jar.name}")
                print(f"  Query     : {q}")
                print(f"\n{Col.yellow}No results found.{Col.reset}")
                c=input("Press Enter to skip to next plugin, or q/back to quit scan: ").strip().lower()
                if c in ("q","quit","exit","b","back"):
                    print(f"\n{tag()} Scan stopped by user. added={added} skipped={skipped} total_jars={total_jars}")
                    return
            continue

        if yes:
            norm=lambda x: re.sub(r"[^a-z0-9]+","",x.lower())
            sel=next((r for r in rs if norm(r.name)==norm(q)),None)
            if not sel:
                skipped+=1; warn(f"No exact match for {jar.name}"); continue
        else:
            visible=min(page_step,len(rs))
            sel=None
            while True:
                clear_screen(); brand()
                context_lines=[
                    f"{Col.bold}Server    :{Col.reset} {s['name']}",
                    f"{Col.bold}Plugin dir:{Col.reset} {s['plugin_dir']}",
                    f"{Col.bold}Plugin    :{Col.reset} {jar.name}",
                    f"{Col.bold}Query     :{Col.reset} {q}",
                ]
                footer=(
                    f"Selecting plugin {idx}/{total_jars}: {jar.name} | "
                    f"Showing 1-{min(visible,len(rs))} of {len(rs)} results | "
                    f"s/next=skip plugin, q/back=quit scan, m=show more"
                )
                print_results(rs, page=1, page_size=visible, title="Track Plugin Search", context_lines=context_lines, footer=footer)
                choice=prompt_result_choice(
                    f"Track which result for {jar.name}?",
                    len(rs),
                    allow_more=True,
                    visible_count=visible,
                    context=f"[selecting plugin {idx}/{total_jars}]"
                )
                if choice == "skip":
                    skipped+=1; sel=None; break
                if choice == "quit":
                    print(f"\n{tag()} Scan stopped by user. added={added} skipped={skipped} total_jars={total_jars}")
                    return
                if choice == "more":
                    if visible < len(rs):
                        visible=min(visible+page_step, len(rs))
                    else:
                        limit += page_step
                        new_rs=search_all(q,sources,limit,"relevance")
                        if len(new_rs) > len(rs):
                            rs=new_rs; visible=min(visible+page_step, len(rs))
                        else:
                            warn("No additional results found.")
                            input("Press Enter to continue...")
                    continue
                sel=rs[choice]
                break
            if not sel:
                continue

        if dry:
            print(f"{Col.yellow}Dry run:{Col.reset} would track {jar.name} as {sel.ref()}")
            if not yes:
                input("Press Enter for next plugin...")
        else:
            try: v=PROVIDERS[sel.provider].latest(sel.project_id)
            except Exception: v=Version(sel.provider,sel.project_id,"",sel.name,sel.rel,sel.api,sel.versions,jar.name,"")
            upsert_reg(s,{"provider":sel.provider,"project_id":sel.project_id,"version_id":v.version_id,"filename":jar.name,"project_name":sel.name,"release_type":v.release_type,"loaders":v.loaders,"game_versions":v.versions,"installed_at":now(),"source":"scan"})
            if yes:
                print(f"{Col.green}Tracked:{Col.reset} {jar.name} -> {sel.ref()}")
            else:
                print(f"\n{Col.green}Tracked:{Col.reset} {jar.name} -> {sel.ref()}")
                input("Press Enter for next plugin...")
        added+=1

    if not yes:
        clear_screen(); brand()
    print(f"\n{tag()} Scan summary: added={added} skipped={skipped} total_jars={total_jars}")

def overview(servers,check=True,details=False):
    print(f"\n{tag()} Server Overview\n")
    print(f"{Col.bold}{'Server':<18} {'Plugins':>7} {'Tracked':>7} {'Untracked':>9} {'Outdated':>8} {'Status':<13} Directory{Col.reset}")
    reports=[]
    for s in servers:
        jars=list(s["plugin_dir"].glob("*.jar")) if s["plugin_dir"].exists() else []
        if s["plugin_dir"].exists(): migrate_reg(s)
        rows=read_reg(s) if s["plugin_dir"].exists() else []
        out=fail=0; detail=[]
        if check:
            for r in rows:
                p=PROVIDERS.get(r.get("provider"))
                if not p: fail+=1; continue
                try:
                    v=p.latest(r.get("project_id",""),(r.get("loaders","").split(",")[0] if r.get("loaders") else ""),(r.get("game_versions","").split(",")[0] if r.get("game_versions") else ""),r.get("release_type",""))
                    if v.version_id and v.version_id != r.get("version_id",""): out+=1; detail.append((r,v,"outdated"))
                except Exception as e: fail+=1; detail.append((r,None,str(e)))
        status="CHECK_FAILED" if fail else "UPDATE" if out else "UNTRACKED" if len(jars)>len(rows) else "OK"
        color={"OK":Col.green,"UPDATE":Col.yellow,"UNTRACKED":Col.blue}.get(status,Col.red)
        print(f"{s['name']:<18} {len(jars):>7} {len(rows):>7} {max(0,len(jars)-len(rows)):>9} {out:>8} {color}{status:<13}{Col.reset} {s['server_dir']}")
        reports.append((s,detail))
    if details:
        for s,detail in reports:
            if detail:
                print(f"\n{Col.bold}{s['name']}{Col.reset}")
                for r,v,reason in detail:
                    if v: print(f"  {Col.yellow}UPDATE{Col.reset} {r.get('project_name')} [{r.get('provider')}] {r.get('version_id') or 'unknown'} -> {v.version_id or 'unknown'}")
                    else: print(f"  {Col.red}CHECK_FAILED{Col.reset} {r.get('project_name')} [{r.get('provider')}] {reason}")

def process_batch(file, default_s, args):
    count=0
    for no,raw in enumerate(Path(file).read_text(errors="replace").splitlines(),1):
        line=raw.split("#",1)[0].strip()
        if not line: continue
        parts=line.split()
        try:
            if default_s:
                s=default_s; ref=parts[0]; name=parts[1] if len(parts)>1 else ""
            else:
                if len(parts)<2: warn(f"Invalid batch line {no}: {raw}"); continue
                s=resolve_server(parts[0]); ref=parts[1]; name=parts[2] if len(parts)>2 else ""
            install_ref(s,ref,args.api,args.mc_version,args.release,name,"batch",args.dry_run); count+=1
        except Exception as e:
            warn(f"Batch line {no} failed: {e}")
            if not truthy(CFG["SPDL_BATCH_CONTINUE_ON_ERROR"]): raise
    print(f"\n{tag()} Batch complete. Processed entries: {count}")

def menu():
    brand()
    while True:
        print(f"{tag()} Main Menu\n  1) Search plugins\n  2) Install by ID / URL / provider ref\n  3) Batch install\n  4) Scan installed plugins\n  5) Update tracked plugins\n  6) Server overview\n  7) List servers\n  0) Exit\n")
        c=input("Select: ").strip()
        if c=="0": return
        if c=="1":
            q=input("Search query: ").strip(); src=input("Source [all/spigot/modrinth/hangar] (all): ").strip() or "all"
            limit=max(search_page_size(), int(CFG["SPDL_SEARCH_LIMIT"])); rs=search_all(q, list(PROVIDERS) if src=="all" else [src], limit, "relevance")
            visible=min(search_page_size(), len(rs)) if rs else search_page_size()
            while True:
                clear_screen(); brand(); print_results(rs, page_size=visible, title=f"Search: {q}", footer=f"Showing 1-{min(visible,len(rs)) if rs else 0} of {len(rs)} results | q/back=main menu, m=show more")
                ch=input("Search menu [m=more / q=back]: ").strip().lower()
                if ch in ("q","quit","b","back",""): break
                if ch in ("m","more","+"):
                    if visible < len(rs): visible=min(visible+search_page_size(), len(rs))
                    else:
                        limit += search_page_size(); new_rs=search_all(q, list(PROVIDERS) if src=="all" else [src], limit, "relevance")
                        if len(new_rs)>len(rs): rs=new_rs; visible=min(visible+search_page_size(), len(rs))
                        else: warn("No additional results found."); input("Press Enter to continue...")
        elif c=="2": install_ref(choose_server(), input("Resource ID / URL / provider ref: ").strip())
        elif c=="3": process_batch(input("Batch file: ").strip(), choose_server(), argparse.Namespace(api="",mc_version="",release="",dry_run=False))
        elif c=="4": scan_server(choose_server(), list(PROVIDERS))
        elif c=="5": update_server(choose_server())
        elif c=="6": overview(list_servers(), True, True)
        elif c=="7": [print(f"{s['name']}\t{s['server_dir']}\t{s['plugin_dir']}") for s in list_servers()]
        else: warn("Invalid choice")

def targets(args):
    if getattr(args,"all",False): return list_servers()
    if getattr(args,"servers",""): return [resolve_server(x.strip()) for x in args.servers.split(",") if x.strip()]
    if getattr(args,"server","") or getattr(args,"server_dir","") or getattr(args,"plugin_dir",""): return [resolve_server(getattr(args,"server",""), getattr(args,"server_dir",""), getattr(args,"plugin_dir",""))]
    return [choose_server()]

def build_parser():
    p=argparse.ArgumentParser(prog="spigotdl", description="SP-DL Minecraft plugin downloader/updater")
    p.add_argument("--version", action="store_true"); p.add_argument("--no-color", action="store_true")
    sub=p.add_subparsers(dest="cmd")
    sub.add_parser("menu"); sub.add_parser("list")
    s=sub.add_parser("search"); s.add_argument("query", nargs="+"); s.add_argument("--source", choices=["spigot","modrinth","hangar","all"], default="all"); s.add_argument("--api", default=""); s.add_argument("--mc-version","--version",dest="mc_version",default=""); s.add_argument("--release", choices=["release","beta","alpha","snapshot"], default=""); s.add_argument("--sort", choices=["relevance","downloads","stars","updated","newest"], default="relevance"); s.add_argument("--limit", type=int, default=25); s.add_argument("--server", default=""); s.add_argument("--server-dir", default=""); s.add_argument("--plugin-dir", default=""); s.add_argument("--install", action="store_true"); s.add_argument("--dry-run", action="store_true")
    i=sub.add_parser("install"); i.add_argument("refs", nargs="+"); i.add_argument("--server","-s",default=""); i.add_argument("--server-dir",default=""); i.add_argument("--plugin-dir",default=""); i.add_argument("--api",default=""); i.add_argument("--mc-version","--version",dest="mc_version",default=""); i.add_argument("--release",choices=["release","beta","alpha","snapshot"],default=""); i.add_argument("--name","-n",default=""); i.add_argument("--dry-run",action="store_true")
    b=sub.add_parser("batch"); b.add_argument("file"); b.add_argument("--server","-s",default=""); b.add_argument("--server-dir",default=""); b.add_argument("--plugin-dir",default=""); b.add_argument("--api",default=""); b.add_argument("--mc-version","--version",dest="mc_version",default=""); b.add_argument("--release",choices=["release","beta","alpha","snapshot"],default=""); b.add_argument("--dry-run",action="store_true")
    sc=sub.add_parser("scan"); sc.add_argument("--server","-s",default=""); sc.add_argument("--server-dir",default=""); sc.add_argument("--plugin-dir",default=""); sc.add_argument("--source",choices=["spigot","modrinth","hangar","all"],default="all"); sc.add_argument("--yes","-y",action="store_true"); sc.add_argument("--dry-run",action="store_true")
    u=sub.add_parser("update"); u.add_argument("--server","-s",default=""); u.add_argument("--servers",default=""); u.add_argument("--all",action="store_true"); u.add_argument("--server-dir",default=""); u.add_argument("--plugin-dir",default=""); u.add_argument("--dry-run",action="store_true")
    o=sub.add_parser("overview"); o.add_argument("--server","-s",default=""); o.add_argument("--servers",default=""); o.add_argument("--all",action="store_true"); o.add_argument("--server-dir",default=""); o.add_argument("--plugin-dir",default=""); o.add_argument("--no-check",action="store_true"); o.add_argument("--details",action="store_true")
    return p

def legacy(argv):
    if argv and not argv[0].startswith("-") and argv[0] not in {"menu","search","install","batch","scan","update","overview","list"} and len(argv)>=2:
        return argparse.Namespace(cmd="install",refs=argv[1:],server=argv[0],server_dir="",plugin_dir="",api="",mc_version="",release="",name="",dry_run=False)
    return None

def main(argv=None):
    argv=list(sys.argv[1:] if argv is None else argv); init_color("--no-color" in argv)
    if not argv: menu(); return
    args=legacy(argv) or build_parser().parse_args(argv)
    if getattr(args,"version",False): print(f"spigotdl {VERSION}"); return
    if args.cmd=="menu": menu(); return
    if args.cmd=="list": [print(f"{s['name']}\t{s['server_dir']}\t{s['plugin_dir']}") for s in list_servers()]; return
    if args.cmd=="search":
        brand(); src=list(PROVIDERS) if args.source=="all" else [args.source]; rs=search_all(" ".join(args.query),src,args.limit,args.sort,args.api,args.mc_version,args.release)
        visible=min(search_page_size(), len(rs)) if rs else search_page_size()
        while True:
            clear_screen(); brand(); print_results(rs, page_size=visible, title="Search Results", footer=f"Showing 1-{min(visible,len(rs)) if rs else 0} of {len(rs)} results")
            if not (rs and (args.server or args.server_dir or args.plugin_dir)):
                if len(rs) > visible:
                    ch=input("Search menu [m=more / q=quit]: ").strip().lower()
                    if ch in ("m","more","+"): visible=min(visible+search_page_size(), len(rs)); continue
                return
            if args.install:
                choice=0
            else:
                choice=prompt_result_choice("Install which result?", len(rs), allow_more=(visible < len(rs)), visible_count=visible)
                if choice == "more": visible=min(visible+search_page_size(), len(rs)); continue
                if choice in ("skip", "quit"): return
            install_ref(resolve_server(args.server,args.server_dir,args.plugin_dir),rs[choice].ref(),args.api,args.mc_version,args.release,"","search",args.dry_run)
            return
    if args.cmd=="install":
        for s in targets(args):
            for ref in args.refs: install_ref(s,ref,args.api,args.mc_version,args.release,args.name,"manual",args.dry_run)
        return
    if args.cmd=="batch": process_batch(args.file, targets(args)[0] if (args.server or args.server_dir or args.plugin_dir) else None, args); return
    if args.cmd=="scan":
        src=list(PROVIDERS) if args.source=="all" else [args.source]
        for s in targets(args): scan_server(s,src,args.yes,args.dry_run)
        return
    if args.cmd=="update":
        for s in targets(args): update_server(s,args.dry_run)
        return
    if args.cmd=="overview":
        ss=targets(args) if (args.server or args.servers or args.all or args.server_dir or args.plugin_dir) else list_servers(); overview(ss, not args.no_check, args.details); return
    menu()
if __name__=="__main__":
    try: main()
    except KeyboardInterrupt: print(); die("Interrupted")
