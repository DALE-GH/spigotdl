class Col:
    reset=bold=dim=red=green=yellow=blue=cyan=gray=""

def truthy(v): return str(v).strip().lower() in {"1","true","yes","y","on"}

def strip_inline_comment(value):
    # Remove comments outside quotes, allowing config like:
    # SPDL_DEFAULT_SOURCE="spigot" # DEFAULT: spigot
    out=[]; quote=None; esc=False
    for ch in value:
        if esc:
            out.append(ch); esc=False; continue
        if ch == "\\":
            out.append(ch); esc=True; continue
        if ch in ("'", '"'):
            if quote is None: quote=ch
            elif quote == ch: quote=None
            out.append(ch); continue
        if ch == "#" and quote is None:
            break
        out.append(ch)
    return "".join(out).strip()

def parse_conf(path):
    out={}
    p=Path(path)
    if not p.exists(): return out
    for raw in p.read_text(errors="replace").splitlines():
        line=raw.strip()
        if not line or line.startswith("#"): continue
        if line.startswith("export "): line=line[7:].strip()
        if "=" not in line: continue
        k,v=line.split("=",1)
        k=k.strip(); v=strip_inline_comment(v.strip())
        if len(v) >= 2 and v[0] == v[-1] and v[0] in ("'", '"'):
            v=v[1:-1]
        if k: out[k]=v
    return out

